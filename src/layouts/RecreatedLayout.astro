---
import CrispChat from "../components/CrispChat.astro";
import GlobalWebflowStyles from "../components/GlobalWebflowStyles.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import type { PageDefinition } from "../data/pages";
import "../styles/global.css";

type Props = {
  page: PageDefinition;
  headHtml: string;
  mainHtml: string;
  htmlClass?: string;
  wfPage?: string;
  wfSite?: string;
};

const { page, headHtml, mainHtml, htmlClass, wfPage, wfSite } = Astro.props;
const canonicalUrl = page.slug ? `https://peak-pim.com/${page.slug}` : "https://peak-pim.com/";
const hasMetaDescription = /<meta\b(?=[^>]*\bname=["']description["'])/i.test(headHtml);
const hasJsonLd = /<script\b(?=[^>]*\btype=["']application\/ld\+json["'])/i.test(headHtml);
const fallbackJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: page.title,
  description: page.description,
  url: canonicalUrl,
  isPartOf: {
    "@type": "WebSite",
    name: "Peak PIM",
    url: "https://peak-pim.com/",
  },
  publisher: {
    "@type": "Organization",
    name: "Peak PIM",
    url: "https://peak-pim.com/",
    logo: "https://peak-pim.com/assets/logo/peak-logo-large.png",
  },
};
---

<!doctype html>
<html
  lang="en"
  data-wf-domain="peak-pim.com"
  data-wf-page={wfPage}
  data-wf-site={wfSite}
  class={htmlClass}
>
  <head>
    <Fragment set:html={headHtml} />
    {!hasMetaDescription && page.description && <meta name="description" content={page.description} />}
    <link rel="canonical" href={canonicalUrl} />
    {!hasJsonLd && <script type="application/ld+json" set:html={JSON.stringify(fallbackJsonLd)} />}
    <link rel="preload" href="/mirror/fonts/V8mDoQDjQSkFtoMM3T6r8E7mPbF4Cw-4ecc7e89b7.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/mirror/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7-6ab57b19c6.woff2" as="font" type="font/woff2" crossorigin />
    <link href="/mirror/local-fonts.css" rel="stylesheet" type="text/css" />
    <meta name="peak-page-slug" content={page.slug || "home"} />
  </head>
  <body>
    <div class="page-wrapper site-page">
      <GlobalWebflowStyles />
      <SiteHeader />
      <div class="site-main" set:html={mainHtml} />
      <SiteFooter />
      <CrispChat />
    </div>
    <script is:inline>
      function setupFaqAccordions() {
        const questions = Array.from(document.querySelectorAll(".faq1_question"));

        questions.forEach((question) => {
          if (question.dataset.faqReady === "true") {
            return;
          }

          const item = question.closest(".faq1_accordion");
          const answer = item && item.querySelector(".faq1_answer");
          const icon = question.querySelector(".faq1_icon-wrapper");

          if (!answer) {
            return;
          }

          question.dataset.faqReady = "true";
          question.setAttribute("role", "button");
          question.setAttribute("tabindex", question.getAttribute("tabindex") || "0");
          question.setAttribute("aria-expanded", "false");
          answer.style.overflow = "hidden";
          answer.style.height = "0px";

          function setOpen(open) {
            question.setAttribute("aria-expanded", String(open));
            answer.style.height = open ? `${answer.scrollHeight}px` : "0px";

            if (icon) {
              icon.style.transform = open ? "rotate(180deg)" : "";
            }
          }

          function toggle() {
            setOpen(question.getAttribute("aria-expanded") !== "true");
          }

          question.addEventListener("click", toggle);
          question.addEventListener("keydown", function(event) {
            if (event.key === "Enter" || event.key === " ") {
              event.preventDefault();
              toggle();
            }
          });
        });

        window.addEventListener("resize", function() {
          questions.forEach((question) => {
            if (question.getAttribute("aria-expanded") !== "true") {
              return;
            }

            const item = question.closest(".faq1_accordion");
            const answer = item && item.querySelector(".faq1_answer");

            if (answer) {
              answer.style.height = `${answer.scrollHeight}px`;
            }
          });
        });
      }

      function setupTimelineProgress() {
        const timelines = Array.from(document.querySelectorAll(".layout121_timeline-wrapper"));

        if (!timelines.length) {
          return;
        }

        let ticking = false;

        function clamp(value) {
          return Math.max(0, Math.min(1, value));
        }

        function update() {
          const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

          timelines.forEach((timeline) => {
            const bar = timeline.querySelector(".layout121_progress-bar");
            const track = timeline.querySelector(".layout121_progress-bar-wrapper");

            if (!bar || !track) {
              return;
            }

            const rect = track.getBoundingClientRect();
            const start = viewportHeight * 0.72;
            const end = viewportHeight * 0.34;
            const distance = rect.height + start - end;
            const progress = distance > 0 ? clamp((start - rect.top) / distance) : 0;

            bar.style.height = `${progress * 100}%`;
          });

          ticking = false;
        }

        function requestUpdate() {
          if (ticking) {
            return;
          }

          ticking = true;
          window.requestAnimationFrame(update);
        }

        update();
        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate);
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", function() {
          setupFaqAccordions();
          setupTimelineProgress();
        });
      } else {
        setupFaqAccordions();
        setupTimelineProgress();
      }
    </script>
  </body>
</html>
