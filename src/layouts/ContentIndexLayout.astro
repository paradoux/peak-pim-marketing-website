---
import CrispChat from "../components/CrispChat.astro";
import GlobalWebflowStyles from "../components/GlobalWebflowStyles.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { formatDate, type ContentEntry } from "../lib/content";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  eyebrow: string;
  emptyMessage: string;
  noindexWhenEmpty?: boolean;
  entries: Array<{
    path: string;
    entry: ContentEntry;
  }>;
};

const { title, description, canonicalPath, eyebrow, emptyMessage, noindexWhenEmpty = true, entries } = Astro.props;
const canonicalUrl = `https://peak-pim.com${canonicalPath}`;
const noindex = noindexWhenEmpty && entries.length === 0;
---

<!doctype html>
<html lang="en" data-wf-domain="peak-pim.com">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        name: title,
        description,
        url: canonicalUrl,
        isPartOf: {
          "@type": "WebSite",
          name: "Peak PIM",
          url: "https://peak-pim.com/",
        },
      })}
    />
    <link rel="preload" href="/mirror/fonts/V8mDoQDjQSkFtoMM3T6r8E7mPbF4Cw-4ecc7e89b7.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/mirror/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7-6ab57b19c6.woff2" as="font" type="font/woff2" crossorigin />
    <link href="/mirror/local-fonts.css" rel="stylesheet" type="text/css" />
  </head>
  <body>
    <div class="page-wrapper site-page">
      <GlobalWebflowStyles />
      <SiteHeader />
      <main class="content-index">
        <section class="content-index-hero">
          <p>{eyebrow}</p>
          <h1>{title}</h1>
          <span>{description}</span>
        </section>

        <section class="content-index-list" aria-label={title}>
          {
            entries.length === 0 ? (
              <div class="content-empty">{emptyMessage}</div>
            ) : (
              entries.map(({ path, entry }) => (
                <a href={path} class="content-card">
                  <span>{formatDate(entry.data.publishDate)}</span>
                  <h2>{entry.data.title}</h2>
                  <p>{entry.data.description}</p>
                </a>
              ))
            )
          }
        </section>
      </main>
      <SiteFooter />
      <CrispChat />
    </div>
  </body>
</html>

<style>
  .content-index {
    min-height: 70vh;
    background: #f6f2ea;
    color: #1d1d1b;
    padding: 7rem 1.25rem 5rem;
  }

  .content-index-hero,
  .content-index-list {
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .content-index-hero {
    padding-bottom: 3rem;
  }

  .content-index-hero p {
    margin: 0 0 1rem;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .content-index-hero h1 {
    margin: 0;
    max-width: 820px;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .content-index-hero span {
    display: block;
    max-width: 680px;
    margin-top: 1.25rem;
    font-size: 1.2rem;
    line-height: 1.5;
  }

  .content-index-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .content-card,
  .content-empty {
    border: 1px solid rgba(29, 29, 27, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.38);
    color: inherit;
    padding: 1.25rem;
    text-decoration: none;
  }

  .content-card span {
    color: rgba(29, 29, 27, 0.66);
    font-size: 0.9rem;
  }

  .content-card h2 {
    margin: 1rem 0 0.75rem;
    font-size: 1.5rem;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .content-card p {
    margin: 0;
    color: rgba(29, 29, 27, 0.74);
    line-height: 1.5;
  }

  .content-empty {
    grid-column: 1 / -1;
  }

  @media (max-width: 900px) {
    .content-index-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .content-index {
      padding-top: 5rem;
    }
  }
</style>
