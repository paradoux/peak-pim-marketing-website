---
import RecreatedLayout from "../layouts/RecreatedLayout.astro";
import { pageSlugs } from "../data/pages";
import { getPage, getPageDocument } from "../lib/page-source";

export const prerender = true;

export function getStaticPaths() {
  return pageSlugs.map((slug) => ({
    params: { slug: slug || undefined },
  }));
}

const page = getPage(Astro.params.slug ?? "");

if (!page) {
  return Astro.redirect("/404");
}

const document = getPageDocument(page);
---

<RecreatedLayout page={page} {...document} />
