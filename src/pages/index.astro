---
const deployMarker = 'Test deploy v1 - 2026-07-02';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Peak PIM test landing page for validating Cloudflare Pages deployments."
    />
    <title>Peak PIM | Cloudflare test landing</title>
  </head>
  <body>
    <main class="page-shell">
      <nav class="topbar" aria-label="Site navigation">
        <a class="brand" href="/">
          <span>P</span>
          Peak PIM
        </a>
        <a class="topbar-link" href="mailto:hello@peakpim.example">Contact</a>
      </nav>

      <section class="hero">
        <div class="copy">
          <p class="eyebrow">Cloudflare Pages test</p>
          <h1>A lightweight landing page for Peak PIM.</h1>
          <p>
            This page is intentionally simple so we can deploy quickly, make a visible change, and confirm that the
            Cloudflare deployment updates correctly.
          </p>
          <div class="actions">
            <a class="button" href="mailto:hello@peakpim.example">Book a demo</a>
            <span class="deploy-marker">{deployMarker}</span>
          </div>
        </div>

        <aside class="status-panel" aria-label="Deployment status">
          <div>
            <span class="status-dot"></span>
            Static Astro build
          </div>
          <div>
            <span class="status-dot"></span>
            Cloudflare Pages ready
          </div>
          <div>
            <span class="status-dot"></span>
            Fast change validation
          </div>
        </aside>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #17201d;
    --muted: #5f6b66;
    --surface: #f5f7f2;
    --panel: #ffffff;
    --line: #dbe4dc;
    --teal: #087c73;
    --lime: #b8dc5a;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    min-height: 100svh;
    margin: 0;
    background: var(--surface);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 76px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 850;
  }

  .brand span {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: 8px;
    background: var(--ink);
    color: var(--lime);
  }

  .topbar-link {
    color: var(--teal);
    font-weight: 800;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
    gap: clamp(28px, 6vw, 72px);
    align-items: center;
    min-height: calc(100svh - 76px);
    padding: 44px 0 72px;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--teal);
    font-size: 0.8rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  h1 {
    max-width: 760px;
    margin: 0 0 20px;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.96;
  }

  p {
    max-width: 620px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.6;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-top: 30px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 8px;
    background: var(--teal);
    color: #ffffff;
    font-weight: 900;
  }

  .deploy-marker {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    padding: 0 14px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.7);
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 800;
  }

  .status-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    box-shadow: 0 24px 60px rgba(23, 32, 29, 0.12);
  }

  .status-panel div {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 46px;
    padding: 0 12px;
    border-radius: 8px;
    background: var(--surface);
    font-weight: 850;
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--lime);
    box-shadow: 0 0 0 4px rgba(184, 220, 90, 0.24);
  }

  @media (max-width: 760px) {
    .page-shell {
      width: min(100% - 32px, 1120px);
    }

    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 34px;
    }

    h1 {
      font-size: clamp(2.7rem, 15vw, 4.7rem);
    }

    .button,
    .deploy-marker {
      width: 100%;
    }
  }
</style>
