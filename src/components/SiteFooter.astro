---
import { getSharedFooterHtml } from "../lib/page-source";

const footerHtml = getSharedFooterHtml().replace(
  '<a href="#" target="_blank" class="footer1_link">Help Center</a>',
  '<a href="https://help.peak-pim.com/en/" target="_blank" rel="noopener" class="footer1_link">Help Center</a>',
).replace(
  '<a href="/pricing" class="footer1_link">Pricing</a>',
  '<a href="/pricing/" class="footer1_link">Pricing</a>',
);
---

<div class="site-footer" set:html={footerHtml} />
