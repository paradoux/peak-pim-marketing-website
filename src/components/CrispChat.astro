<script is:inline>
  window.$crisp = window.$crisp || [];
  window.CRISP_WEBSITE_ID = "5d573a39-3d86-4529-84ff-db612ac593d1";
  window.__loadPeakCrisp = function() {
    if (window.__peakCrispLoaded) {
      return;
    }

    window.__peakCrispLoaded = true;

    var script = document.createElement("script");
    script.src = "https://client.crisp.chat/l.js";
    script.async = true;
    document.head.appendChild(script);
  };

  if ("requestIdleCallback" in window) {
    window.requestIdleCallback(window.__loadPeakCrisp, { timeout: 3500 });
  } else {
    window.setTimeout(window.__loadPeakCrisp, 2500);
  }

  ["pointerdown", "keydown", "touchstart", "scroll"].forEach(function(eventName) {
    window.addEventListener(eventName, window.__loadPeakCrisp, { once: true, passive: true });
  });
</script>

<script is:inline>
  function openCrispChat(attempt) {
    window.$crisp = window.$crisp || [];
    window.__loadPeakCrisp && window.__loadPeakCrisp();
    window.$crisp.push(['do', 'chat:open']);

    if (attempt < 10 && !document.querySelector('iframe[src*="crisp.chat"], [class*="crisp-client"]')) {
      setTimeout(function() {
        openCrispChat(attempt + 1);
      }, 300);
    }
  }

  document.addEventListener('click', function(e) {
    var trigger = e.target.closest("[data-open-crisp]");

    if (trigger) {
      e.preventDefault();
      openCrispChat(0);
    }
  });
</script>
