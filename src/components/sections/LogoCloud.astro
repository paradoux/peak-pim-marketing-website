---
import { assets } from "../../data/assets";

type LogoKey = keyof typeof assets.customerLogos.light;
type Props = { title?: string };

const { title = "Trusted by Shopify merchants worldwide" } = Astro.props;
const firstList: LogoKey[] = ["tupperware", "duBruit", "maeli", "artefact", "duBruit", "gullyLabs", "lafaurie", "aurevia"];
const secondList: LogoKey[] = ["carreCoco", "tupperware", "duBruit", "artefact", "gullyLabs", "aurevia", "carreCoco", "lafaurie"];
---

<section class="section_logo3 peak-logo-cloud color-scheme-1" aria-label={title}>
  <div class="padding-section-medium">
    <div class="padding-global">
      <div class="container-large">
        <div class="margin-bottom margin-large">
          <div class="text-align-center">
            <div class="max-width-large align-center"><h2 class="heading-style-h6-logos">{title}</h2></div>
          </div>
        </div>
      </div>
    </div>
    <div class="logo3_component peak-logo-cloud__component">
      {[firstList, secondList].map((logos) => (
        <div class="logo3_list peak-logo-cloud__list">
          {logos.map((key) => (
            <div class="logo3_wrapper peak-logo-cloud__item"><img class="logo3_logo peak-logo-cloud__logo" src={assets.customerLogos.light[key]} alt="" loading="lazy" /></div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
